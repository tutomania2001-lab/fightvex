# FightVex — environment variables (copy to .env.local and fill in)

# Free key from https://the-odds-api.com (free tier ~500 requests/month).
# Used only by scripts/fetch-odds.mjs to cache real MMA odds locally.
# Never shipped to the browser.
THE_ODDS_API_KEY=

# Upstash Redis (free tier) — powers BOTH the live odds feed and user
# accounts (emails, scrypt password hashes, sessions). Get them from the
# Upstash dashboard or the Vercel → Storage integration. Server-only.
# Either the Vercel KV names or the Upstash names work.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Protects the scheduled odds cron route (/api/cron/odds).
CRON_SECRET=

# ---- Stripe billing ----
# Users self-register (free plan) and upgrade by purchasing; the checkout is
# tied to their account and the webhook upgrades THAT account on payment.
# Secret API key (Developers → API keys). Server-only.
STRIPE_SECRET_KEY=
# Signing secret of the webhook endpoint you add in Stripe (Developers →
# Webhooks → your /api/stripe/webhook endpoint → Signing secret). Server-only.
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs for each paid plan (Product catalog → your prices).
# NEXT_PUBLIC_ so the client can request the right plan; the price→plan map
# is enforced server-side.
NEXT_PUBLIC_STRIPE_PRICE_PRO=
NEXT_PUBLIC_STRIPE_PRICE_ELITE=

# ---- Supabase (Postgres + Auth) ----
# Project API settings: Supabase dashboard → Project Settings → API.
# URL + anon key are public (RLS protects the data); service_role bypasses RLS
# and must stay server-only. Until these are set, the app falls back to the
# existing custom auth and the Supabase middleware no-ops.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
